PORT=3000
HOST=0.0.0.0
NODE_ENV=development

SESSION_SECRET=replace-with-a-long-random-value

# Use either a URI containing credentials, or a credential-free URI together
# with MONGODB_USERNAME and MONGODB_PASSWORD.
DATABASE_URL=mongodb+srv://cluster.example.mongodb.net/cloverapp?retryWrites=true&w=majority
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB_NAME=cloverapp

BROWSER_HEADLESS=1
PUPPETEER_CACHE_DIR=.cache/puppeteer

CHECK_NAVIGATION_TIMEOUT_MS=60000
CHECK_POST_SUBMIT_WAIT_MS=8000
PROXY_CHECK_TIMEOUT_MS=12000
CHECK_PROGRESS_DELAY_MS=1000
CHECK_ATTEMPT_DELAY_MS=2000
