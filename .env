# Sunucu
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Session
SESSION_SECRET=your-super-secret-key-change-this

# MongoDB
MONGODB_CONNECTIONSTRING=mongodb+srv://paymentmanger.gvaavzc.mongodb.net/?authSource=%24external&authMechanism=MONGODB-X509&appName=paymentmanger


# Puppeteer
BROWSER_HEADLESS=new
PUPPETEER_CACHE_DIR=.cache/puppeteer

# Timeout Ayarları
CHECK_NAVIGATION_TIMEOUT_MS=45000
CHECK_FORM_TIMEOUT_MS=15000
CHECK_POST_SUBMIT_WAIT_MS=5000
PROXY_CHECK_TIMEOUT_MS=12000
CHECK_PROGRESS_DELAY_MS=1000
CHECK_ATTEMPT_DELAY_MS=2000

PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome